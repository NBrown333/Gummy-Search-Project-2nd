    def __init__(self) -> None:
        """Initialize the finder"""
        self.products: List[GummyBearProduct] = []
        self.session: requests.Session = self._create_session()

    @staticmethod
    def _create_session() -> requests.Session:
        """Create a requests session with proper headers"""
        session = requests.Session()
        session.headers.update({
            'User-Agent': 'GummyBearPriceFinder/1.0 (OpenStreetMap)'
        })
        return session

    @lru_cache(maxsize=128)
    def get_coordinates_from_address(self, address: str) -> Optional[tuple[float, float]]:
        """
        Get latitude and longitude from address using Nominatim (OpenStreetMap)
        
        Args:
            address: Location address or city name
            
        Returns:
            Tuple of (latitude, longitude) or None if not found
        """
        try:
            url = "https://nominatim.openstreetmap.org/search"
            params = {
                "q": address,
                "format": "json",
                "limit": 1
            }
            
            response = self.session.get(url, params=params, timeout=10)
            response.raise_for_status()
            
            data = response.json()
            if data:
                result = data[0]
                lat = float(result['lat'])
                lon = float(result['lon'])
                logger.info(f"Found coordinates for {address}: ({lat:.4f}, {lon:.4f})")
                return (lat, lon)
            else:
                logger.warning(f"Could not find location: {address}")
                return None
                
        except requests.exceptions.RequestException as e:
            logger.error(f"Error getting coordinates: {e}")
            return None

    @staticmethod
    def calculate_distance(lat1: float, lon1: float, lat2: float, lon2: float) -> float:
        """
        Calculate distance between two coordinates in miles using Haversine formula
        
        Args:
            lat1, lon1: First coordinate
            lat2, lon2: Second coordinate
            
        Returns:
            Distance in miles
        """
        from math import radians, cos, sin, asin, sqrt
        
        lon1, lat1, lon2, lat2 = map(radians, [lon1, lat1, lon2, lat2])
        dlon = lon2 - lon1
        dlat = lat2 - lat1
        a = sin(dlat/2)**2 + cos(lat1) * cos(lat2) * sin(dlon/2)**2
        c = 2 * asin(sqrt(a))
        r = 3959  # Radius of earth in miles
        return c * r

    def find_local_stores(self, location: str, distance_miles: float) -> List[Dict]:
        """
        Find local stores selling gummy bears within specified distance
        Uses Overpass API (OpenStreetMap data)
        
        Args:
            location: Location to search from
            distance_miles: Search radius in miles
            
        Returns:
            List of store dictionaries
        """
        try:
            # Get coordinates for the location
            coords = self.get_coordinates_from_address(location)
            if not coords:
                return []
            
            lat, lon = coords
            
            logger.info(f"Searching for stores within {distance_miles} miles...")
            stores = self._search_stores_overpass(lat, lon, distance_miles)
            
            if stores:
                logger.info(f"Found {len(stores)} nearby stores")
            else:
                logger.warning("No stores found in OpenStreetMap data")
            
            return stores
        
        except Exception as e:
            logger.error(f"Error finding local stores: {e}")
            return []

    def _search_stores_overpass(self, lat: float, lon: float, distance_miles: float) -> List[Dict]:
        """
        Search for stores using Overpass API
        
        Args:
            lat, lon: Center coordinates
            distance_miles: Search radius in miles
            
        Returns:
            List of store dictionaries
        """
        try:
            # Convert miles to km for Overpass bbox
            distance_km = distance_miles * 1.60934
            
            # Create bbox (south, west, north, east)
            bbox = (
                lat - (distance_km / 111),
                lon - (distance_km / 111),
                lat + (distance_km / 111),
                lon + (distance_km / 111)
            )
            
            # Overpass QL query for supermarkets and health stores
            overpass_query = f"""
            [bbox:{bbox[0]},{bbox[1]},{bbox[2]},{bbox[3]}];
            (
              node["shop"="supermarket"];
              way["shop"="supermarket"];
              node["shop"="health"];
              way["shop"="health"];
              node["shop"="convenience"];
              way["shop"="convenience"];
            );
            out center;
            """
            
            url = "https://overpass-api.de/api/interpreter"
            response = self.session.post(url, data=overpass_query, timeout=30)
            response.raise_for_status()
            
            stores: List[Dict] = []
            data = response.json()
            
            for element in data.get("elements", []):
                store = {
                    "name": element.get("tags", {}).get("name", "Store"),
                    "type": element.get("tags", {}).get("shop", "store"),
                    "lat": element.get("center", {}).get("lat") or element.get("lat"),
                    "lon": element.get("center", {}).get("lon") or element.get("lon"),
                    "address": element.get("tags", {}).get("addr:full", ""),
                }
                
                if store["lat"] and store["lon"]:
                    stores.append(store)
            
            return stores[:20]  # Limit to 20 stores
            
        except Exception as e:
            logger.error(f"Error with Overpass API: {e}")
            logger.info("Using fallback store data...")
            return self._get_fallback_stores()

    @staticmethod
    def _get_fallback_stores() -> List[Dict]:
        """Fallback store data when Overpass API is unavailable"""
        return [
