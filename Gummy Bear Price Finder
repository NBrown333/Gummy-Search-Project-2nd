        Args:
            stores: List of store dictionaries
            user_lat, user_lon: User coordinates for distance calculation
            
        Returns:
            List of GummyBearProduct objects
        """
        products: List[GummyBearProduct] = []
        
        # Sample products that might be available at local stores
        sample_products = [
            {
                "name": "Organic Gummy Bears",
                "brand": "Nature's Way",
                "size_oz": 5,
                "price": 4.99,
                "artificial_ingredients": []
