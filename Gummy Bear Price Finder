    format='%(asctime)s - %(name)s - %(levelname)s - %(message)s'
)
logger = logging.getLogger(__name__)


class StoreType(Enum):
    """Enumeration for store types"""
    LOCAL = "local"
    ONLINE = "online"


@dataclass
class GummyBearProduct:
    """Represents a gummy bear product with pricing information"""
    name: str
    brand: str
    size_oz: float
    price: float
    store_name: str
    store_type: StoreType
    address: Optional[str] = None
    distance_miles: Optional[float] = None
    shipping_cost: float = 0.0
    artificial_ingredients: List[str] = field(default_factory=list)
    url: Optional[str] = None
    last_updated: str = field(default_factory=lambda: datetime.now().isoformat())

    @property
    def total_cost(self) -> float:
        """Calculate total cost including shipping"""
        return self.price + self.shipping_cost

    @property
    def cost_per_ounce(self) -> float:
        """Calculate cost per ounce"""
        if self.size_oz <= 0:
            return float('inf')
        return self.total_cost / self.size_oz

    @property
    def is_natural(self) -> bool:
        """Check if product has no artificial ingredients"""
        return len(self.artificial_ingredients) == 0

    def __str__(self) -> str:
        cost_display = f"${self.cost_per_ounce:.2f}/oz"
        store_display = f"{self.store_name}"
        
        if self.store_type == StoreType.LOCAL and self.distance_miles:
            store_display += f" ({self.distance_miles:.1f} mi away)"
        elif self.store_type == StoreType.ONLINE:
            store_display += " (Online)"
        
        return (f"{self.brand} {self.name} | {self.size_oz}oz | {cost_display} | "
                f"{store_display} | Total: ${self.total_cost:.2f}")

    def to_dict(self) -> Dict:
        """Convert to dictionary"""
        return {
            'name': self.name,
            'brand': self.brand,
            'size_oz': self.size_oz,
            'price': self.price,
            'store_name': self.store_name,
            'store_type': self.store_type.value,
            'address': self.address,
            'distance_miles': self.distance_miles,
            'shipping_cost': self.shipping_cost,
            'artificial_ingredients': self.artificial_ingredients,
            'url': self.url,
            'total_cost': self.total_cost,
            'cost_per_ounce': self.cost_per_ounce,
            'is_natural': self.is_natural,
            'last_updated': self.last_updated
        }


