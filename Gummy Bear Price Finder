            },
            {
                "name": "Gummy Bears",
                "brand": "Haribo",
                "size_oz": 12,
                "price": 9.99,
                "artificial_ingredients": ["gelatin"]
            }
        ]
        
        for store in stores:
            store_lat = store.get("lat", 0)
            store_lon = store.get("lon", 0)
            
            if store_lat and store_lon:
                distance = self.calculate_distance(user_lat, user_lon, store_lat, store_lon)
            else:
                distance = 0.5
            
            for product in sample_products:
                products.append(GummyBearProduct(
                    name=product["name"],
                    brand=product["brand"],
                    size_oz=product["size_oz"],
                    price=product["price"],
                    store_name=store["name"],
                    store_type=StoreType.LOCAL,
                    address=store["address"],
                    distance_miles=distance,
                    artificial_ingredients=product["artificial_ingredients"]
                ))
        
        return products

    def find_online_products(self) -> List[GummyBearProduct]:
        """
        Find online gummy bear products from major retailers
        
        Returns:
            List of GummyBearProduct objects
        """
        products: List[GummyBearProduct] = []
        
        for source in self.ONLINE_RETAILERS:
            retailer = source["retailer"]
            retailer_url = source["url"]
            
            for product in source["products"]:
                products.append(GummyBearProduct(
                    name=product["name"],
                    brand=product["brand"],
                    size_oz=product["size_oz"],
                    price=product["price"],
                    store_name=retailer,
                    store_type=StoreType.ONLINE,
                    shipping_cost=product["shipping"],
                    artificial_ingredients=product["artificial_ingredients"],
                    url=retailer_url,
                    address=None,
                    distance_miles=None
                ))
        
        return products

    def filter_natural_products(self, products: List[GummyBearProduct]) -> List[GummyBearProduct]:
        """
        Filter products to only natural ones (no artificial ingredients)
        
        Args:
            products: List of products to filter
            
        Returns:
            Filtered list of natural products
        """
        return [p for p in products if p.is_natural]

    def find_cheapest_gummy_bears(
        self,
        location: str,
        distance_miles: float,
        include_online: bool = True
    ) -> List[GummyBearProduct]:
        """
        Main method to find the cheapest natural gummy bears
        
        Args:
            location: Search location
            distance_miles: Search radius in miles
            include_online: Include online retailers
            
        Returns:
            Sorted list of GummyBearProduct objects
        """
        all_products: List[GummyBearProduct] = []
        
        # Get local products
        logger.info(f"Searching for stores within {distance_miles} miles of {location}...")
        local_stores = self.find_local_stores(location, distance_miles)
        
        if local_stores:
            # Get user coordinates for distance calculation
            coords = self.get_coordinates_from_address(location)
            if coords:
                user_lat, user_lon = coords
                local_products = self.get_local_product_prices(local_stores, user_lat, user_lon)
                all_products.extend(local_products)
        
        # Get online products if requested
        if include_online:
            logger.info("Searching online retailers...")
            online_products = self.find_online_products()
            all_products.extend(online_products)
        
        # Filter for natural products only
        natural_products = self.filter_natural_products(all_products)
        
        if not natural_products:
            logger.warning("No natural gummy bears found matching criteria")
            return []
        
        # Sort by cost per ounce
        natural_products.sort(key=lambda p: p.cost_per_ounce)
        
        self.products = natural_products
        logger.info(f"Found {len(natural_products)} natural gummy bear options")
        return natural_products

    def display_results(self, limit: int = 10) -> None:
        """
        Display the results in a formatted table
        
        Args:
            limit: Maximum number of results to display
        """
        if not self.products:
            logger.warning("No natural gummy bears found matching criteria")
            return
        
        print("\n" + "="*130)
        print("🍬 CHEAPEST NATURAL GUMMY BEARS - SORTED BY COST PER OUNCE 🍬")
        print("="*130)
        
        for idx, product in enumerate(self.products[:limit], 1):
            print(f"\n#{idx}. {product.brand} - {product.name}")
            print(f"    Size: {product.size_oz} oz | Cost/oz: ${product.cost_per_ounce:.2f}")
            print(f"    Price: ${product.price:.2f}", end="")
            
            if product.shipping_cost > 0:
                print(f" | Shipping: ${product.shipping_cost:.2f}")
            else:
                print()
            
            if product.store_type == StoreType.LOCAL:
                print(f"    📍 Store: {product.store_name} ({product.distance_miles:.1f} mi)")
                if product.address:
                    print(f"    📬 Address: {product.address}")
            else:
                print(f"    🛒 Retailer: {product.store_name} (Online)")
                if product.url:
                    print(f"    🔗 Link: {product.url}")
            
            print(f"    💰 Total Cost: ${product.total_cost:.2f}")

    def export_to_csv(self, filename: str = "gummy_bears_prices.csv") -> bool:
        """
        Export results to CSV file
        
        Args:
            filename: Output filename
            
        Returns:
            True if successful, False otherwise
        """
        if not self.products:
            logger.warning("No products to export")
            return False
        
        try:
            filepath = Path(filename)
            with filepath.open('w', newline='', encoding='utf-8') as csvfile:
                fieldnames = [
                    'Rank', 'Brand', 'Name', 'Size (oz)', 'Price', 'Shipping',
                    'Total Cost', 'Cost/oz', 'Store', 'Type', 'Distance (mi)', 'Address'
                ]
                writer = csv.DictWriter(csvfile, fieldnames=fieldnames)
                
                writer.writeheader()
                for idx, product in enumerate(self.products, 1):
                    writer.writerow({
                        'Rank': idx,
                        'Brand': product.brand,
                        'Name': product.name,
                        'Size (oz)': product.size_oz,
                        'Price': f"${product.price:.2f}",
                        'Shipping': f"${product.shipping_cost:.2f}",
                        'Total Cost': f"${product.total_cost:.2f}",
                        'Cost/oz': f"${product.cost_per_ounce:.2f}",
                        'Store': product.store_name,
                        'Type': product.store_type.value,
                        'Distance (mi)': f"{product.distance_miles:.1f}" if product.distance_miles else 'Online',
                        'Address': product.address or 'N/A'
                    })
            
            logger.info(f"Results exported to {filename}")
            return True
        
        except Exception as e:
            logger.error(f"Error exporting to CSV: {e}")
            return False


def main() -> None:
    """Main entry point for the CLI application"""
    print("\n" + "="*50)
    print("🍬 GUMMY BEAR PRICE FINDER 🍬")
    print("="*50)
    print("Find the cheapest natural gummy bears in your area!")
    print("="*50 + "\n")
    
    # Initialize finder
    finder = GummyBearFinder()
    
    # Get user input
    location = input("📍 Enter your location (city, state or address): ").strip()
    if not location:
        logger.error("Location is required!")
        return
    
    while True:
        try:
            distance_input = input("📏 Enter search distance in miles (e.g., 5, 10, 25): ")
            distance = float(distance_input)
            if distance <= 0:
                print("❌ Distance must be greater than 0.")
                continue
            if distance > 500:
                print("⚠️  Distance is very large. Limiting to 500 miles.")
                distance = 500
            break
        except ValueError:
            print("❌ Please enter a valid number.")
    
    include_online_input = input("🌐 Include online retailers? (yes/no) [default: yes]: ").strip().lower()
    include_online = include_online_input != 'no'
    
    # Find the cheapest options
    print("\n🔍 Searching for the best deals...\n")
    results = finder.find_cheapest_gummy_bears(location, distance, include_online)
    
    # Display results
    if results:
        finder.display_results(limit=10)
    
    # Ask if user wants to export
    export_input = input("\n💾 Export results to CSV? (yes/no) [default: no]: ").strip().lower()
    if export_input == 'yes':
        finder.export_to_csv()
    
    print("\n✓ Thank you for using Gummy Bear Price Finder!")


if __name__ == "__main__":
    main()
